# ─── Supabase ─────────────────────────────────────────────────────────────────
# Encontre esses valores em: https://supabase.com → seu projeto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=SUA_CHAVE_ANONIMA

# ─── TOTVS RM ─────────────────────────────────────────────────────────────────
# URL da consulta SQL de busca por CPF (consultaSQLServer)
TOTVS_RM_CPF_URL=https://seu-servidor.rm.cloudtotvs.com.br:8051/api/framework/v1/consultaSQLServer/RealizaConsulta/API.02/1/P
TOTVS_RM_USERNAME=seu_usuario_totvs
TOTVS_RM_PASSWORD=sua_senha_totvs

# ─── Autenticação da área de consulta ─────────────────────────────────────────
# Credenciais de acesso à página /consulta
AUTH_USERNAME=usuario_acesso
AUTH_PASSWORD=senha_acesso

# Segredo do cookie de sessão — use uma string longa e aleatória em produção
# Exemplo: openssl rand -base64 32
AUTH_SECRET=troque-por-uma-string-aleatoria-longa
